{
  "feature": "001-typescript-to-zig-native",
  "cases": [
    {
      "id": "native.valid.hello",
      "source": "../examples/valid/hello.ts",
      "phase": "compile-run",
      "expect": {
        "stdout": "7"
      }
    },
    {
      "id": "native.valid.types",
      "source": "../examples/valid/types.ts",
      "phase": "static",
      "expect": {
        "inferredTypes": {
          "a": "int"
        },
        "acceptedTypes": [
          "int",
          "i32"
        ]
      }
    },
    {
      "id": "native.valid.named-type",
      "source": "../examples/valid/named-type.ts",
      "phase": "compile-run",
      "expect": {
        "stdout": "7"
      }
    },
    {
      "id": "native.valid.let-reassign",
      "source": "../examples/valid/let-reassign.ts",
      "phase": "compile-run",
      "expect": {
        "stdout": "3"
      }
    },
    {
      "id": "native.valid.log-string",
      "source": "../examples/valid/log-string.ts",
      "phase": "compile-run",
      "expect": {
        "stdout": "hello"
      }
    },
