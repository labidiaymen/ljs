{
  "feature": "001-typescript-to-zig-native",
  "cases": [
    {
      "id": "native.valid.hello",
      "source": "../examples/valid/hello.ts",
      "phase": "compile-run",
      "expect": {
        "stdout": "7"
      }
    },
    {
      "id": "native.valid.types",
      "source": "../examples/valid/types.ts",
      "phase": "static",
      "expect": {
        "inferredTypes": {
          "a": "int"
        },
        "acceptedTypes": [
          "int",
          "i32"
        ]
      }
    },
    {
      "id": "native.valid.named-type",
      "source": "../examples/valid/named-type.ts",
      "phase": "compile-run",
      "expect": {
        "stdout": "7"
      }
    },
    {
      "id": "native.valid.let-reassign",
      "source": "../examples/valid/let-reassign.ts",
      "phase": "compile-run",
      "expect": {
        "stdout": "3"
      }
    },
    {
      "id": "native.valid.log-string",
      "source": "../examples/valid/log-string.ts",
      "phase": "compile-run",
      "expect": {
        "stdout": "hello"
      }
    },
    {
      "id": "native.valid.bool-literal",
      "source": "../examples/valid/bool-literal.ts",
      "phase": "compile-run",
      "expect": {
        "stdout": "true"
      }
    },
    {
      "id": "native.valid.if-else",
      "source": "../examples/valid/if-else.ts",
      "phase": "compile-run",
      "expect": {
        "stdout": "yes"
      }
    },
    {
      "id": "native.invalid.eval",
      "source": "../examples/invalid/eval.ts",
      "phase": "diagnostics",
      "expect": {
        "diagnostic": "E_UNSUPPORTED_EVAL"
      }
    },
    {
      "id": "native.invalid.prototype",
      "source": "../examples/invalid/prototype.ts",
      "phase": "diagnostics",
      "expect": {
        "diagnostic": "E_UNSUPPORTED_PROTOTYPE"
      }
    },
    {
      "id": "native.invalid.commonjs",
      "source": "../examples/invalid/commonjs.ts",
      "phase": "diagnostics",
      "expect": {
        "diagnostic": "E_UNSUPPORTED_COMMONJS"
      }
    },
    {
      "id": "native.invalid.type-mismatch",
      "source": "../examples/invalid/type-mismatch.ts",
      "phase": "diagnostics",
      "expect": {
        "diagnostic": "E_TYPE_MISMATCH"
      }
    },
    {
      "id": "native.invalid.const-reassign",
      "source": "../examples/invalid/const-reassign.ts",
      "phase": "diagnostics",
      "expect": {
        "diagnostic": "E_CONST_ASSIGNMENT"
      }
    },
    {
      "id": "native.invalid.if-condition-type",
      "source": "../examples/invalid/if-condition-type.ts",
      "phase": "diagnostics",
      "expect": {
        "diagnostic": "E_TYPE_MISMATCH"
      }
    },
    {
      "id": "native.invalid.named-type-field-mismatch",
      "source": "../examples/invalid/named-type-field-mismatch.ts",
      "phase": "diagnostics",
      "expect": {
        "diagnostic": "E_TYPE_MISMATCH"
      }
    },
    {
      "id": "native.invalid.dynamic-property-write",
      "source": "../examples/invalid/dynamic-property-write.ts",
      "phase": "diagnostics",
      "expect": {
        "diagnostic": "E_DYNAMIC_PROPERTY_WRITE"
      }
    },
    {
      "id": "native.invalid.dynamic-property-dot",
      "source": "../examples/invalid/dynamic-property-dot.ts",
      "phase": "diagnostics",
      "expect": {
        "diagnostic": "E_DYNAMIC_PROPERTY_WRITE"
      }
    }
  ]
}
