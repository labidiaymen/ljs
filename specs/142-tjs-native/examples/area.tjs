// typed-JS example — types are real (not erased), the program compiles to a NATIVE binary.
//   ljs compile area.tjs   →   area.exe   (prints 40 / 50 / 22)

let width: int = 8;          // int  → i64
let height: int = 5;
let area: int = width * height;
console.log(area);           // 40
console.log(area + 10);      // 50

let base: number = 3;        // number → f64
let scaled: number = (base + width) * 2;
console.log(scaled);         // 22
