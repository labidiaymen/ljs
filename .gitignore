# Zig build artifacts
.zig-cache/
zig-out/
# Fetched package dependencies (libxev, spec 107) — pinned by hash in build.zig.zon, not vendored
zig-pkg/

# Spec Kit / agent (may contain credentials)
.claude/

# OS
.DS_Store

# Lumen generated backend artifacts
.lumen-*.zig

# Lumen runtime fetch caches (wasm-link archives, the libxev async runtime
# source) -- fetched on demand by the compiler, not vendored
.lumen-wasmlink-*.a
.lumen-libxev-*/
